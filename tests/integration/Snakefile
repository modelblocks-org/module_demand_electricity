# Emulate a user configuring the module.
configfile: workflow.source_path("./test_config.yaml")


# Emulate how another workflow might create inputs for this module.
rule copy_resources:
    input:
        shapes_small="resources/user/shapes_NLD_NUTS2.parquet",
        shapes_large="resources/user/shapes_Europe_NUTS2.parquet",
    output:
        shapes_small="results/module_demand_electricity/resources/user/shapes_NLD_NUTS2.parquet",
        shapes_large="results/module_demand_electricity/resources/user/shapes_Europe_NUTS2.parquet",
    message:
        "Example of a rule external to your module."
    shell:
        """
        cp {input.shapes_small} {output.shapes_small}
        cp {input.shapes_large} {output.shapes_large}
        """


# Import the module and configure it.
# `snakefile:` specifies the module. It can use file paths and special github(...) / gitlab(...) markers
# `prefix:` re-routes all input/output paths of the module, helping to avoid file conflicts.
module module_demand_electricity:
    pathvars:
        token_entsoe="resources/user/token_entsoe.txt",
        countries="resources/user/countries.parquet",
    snakefile:
        "../../workflow/Snakefile"
    config:
        config["integration_test"]


# rename all module rules with a prefix, to avoid naming conflicts.
use rule * from module_demand_electricity as module_demand_electricity_*


# Europe test case
rule example_europe:
    input:
        "results/demand_electricity_Europe_NUTS2_MW.parquet",
    message:
        "A test case for Europe."


# Netherlands test case
rule example_nld:
    default_target: True
    input:
        "results/demand_electricity_NLD_NUTS2_MW.parquet",
    message:
        "A test case for Netherlands."
