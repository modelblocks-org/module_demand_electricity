# Emulate a user configuring the module.
configfile: workflow.source_path("./test_config.yaml")


# Emulate how another workflow might create inputs for this module.
rule copy_resources:
    message:
        "Example of a rule external to your module."
    input:
        shapes="../files/shapes.parquet",
        countries="../files/shapes_national.parquet",
    output:
        shapes="results/module_demand_electricity/resources/user/shapes.parquet",
        countries="results/module_demand_electricity/resources/user/countries.parquet",
    shell:
        """
        cp {input.shapes} {output.shapes}
        cp {input.countries} {output.countries}
        """


# Import the module and configure it.
# `snakefile:` specifies the module. It can use file paths and special github(...) / gitlab(...) markers
# `prefix:` re-routes all input/output paths of the module, helping to avoid file conflicts.
module module_demand_electricity:
    snakefile:
        "../../workflow/Snakefile"
    config:
        config["module_demand_electricity"]
    prefix:
        "results/module_demand_electricity"


# rename all module rules with a prefix, to avoid naming conflicts.
use rule * from module_demand_electricity as module_demand_electricity_*


# Request something from the module
rule all:
    message:
        "A test case."
    default_target: True
    input:
        "results/module_demand_electricity/results/demand_electricity_polygon_profiles.parquet",
